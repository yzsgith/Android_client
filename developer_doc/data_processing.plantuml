@startuml
title 数据转换处理功能（精确版）

participant "DataProcessRepository" as Repo
participant "ProcessorRegistry" as Registry
participant "ProcessorChain" as Chain
participant "HeartRateSmoother" as Smoother
participant "HeartRateAnalyzer" as Analyzer

Repo -> Registry: getChain(dataType: KClass<out RawData>)
Registry --> Repo: ProcessorChain
Repo -> Chain: execute(input: Any)
Chain -> Smoother: process(input: RawHeartRate)
Smoother --> Chain: SmoothedHeartRate
Chain -> Analyzer: process(input: SmoothedHeartRate)
Analyzer --> Chain: HeartRateAlert
Chain --> Repo: ConsumableData
@enduml